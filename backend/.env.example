# ─────────────────────────────────────────────────────
#  BrandMeld Backend — Environment Variable Reference
#  Copy this file to .env and fill in real values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────

# Required for CORS (Frontend communication)
# Comma-separated list. Used by the backend to allow requests from your frontend.
# Set this to your frontend URL in production (e.g. https://your-frontend-app.web.app)
# For local dev, we already default to localhost and common dev ports in code, 
# but you can add explicit ones here.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Supabase project URL
# Get from: Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Google Gemini API Key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Supabase Service Role Key (server-side only — never expose to browser)
# Get from: Supabase Dashboard → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase JWT Secret — used by the API auth middleware to verify user tokens
# Get from: Supabase Dashboard → Project Settings → API → JWT Settings → JWT Secret
# REQUIRED in production. Without this, auth middleware is disabled (dev mode only).
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# Comma-separated list of allowed CORS origins (no trailing slashes)
# Example: https://brandmeld.run.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
