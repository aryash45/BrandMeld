# ─────────────────────────────────────────────────────────────────────────────
#  BrandMeld Frontend — Environment Variable Reference
#  Copy this file to .env and fill in real values.
#  VITE_ prefix is required for Vite to expose variables to the browser bundle.
#  NEVER put secret keys here — only public/anon keys.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL (no trailing slash)
VITE_API_URL=http://localhost:8080

# Supabase project URL (safe to expose — public)
# Get from: Supabase Dashboard → Project Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (safe to expose — governed by RLS policies)
# Get from: Supabase Dashboard → Project Settings → API → anon public
VITE_SUPABASE_ANON_KEY=your-anon-key-here
